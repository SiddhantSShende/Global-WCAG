# ─────────────────────────────────────────────────────────────
# Copy to `.env` and adjust. NEVER commit a real .env.
# ─────────────────────────────────────────────────────────────

# ── Database ──
DATABASE_URL=postgresql+psycopg2://a11y:a11y@postgres:5432/a11y

# ── Broker / result backend (Redis or Valkey — same protocol) ──
REDIS_URL=redis://broker:6379/0

# ── Object storage (S3-compatible: MinIO / Garage / AWS S3) ──
S3_ENDPOINT=http://objectstore:9000
S3_BUCKET=a11y-artifacts
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# ── Scan scoping / politeness defaults ──
MAX_PAGES_PER_HOST=100
CRAWL_MAX_DEPTH=2
HOST_RATE_LIMIT_PER_SEC=3
HONOR_ROBOTS_TXT=true
SCAN_USER_AGENT=A11yAuditBot/1.0 (+https://your-org.example/a11y-bot)

# ── OSINT source API keys (optional but recommended; passive sources) ──
# subfinder reads its own provider-config.yaml; these are for direct API calls.
CERTSPOTTER_API_TOKEN=
CHAOS_API_KEY=
VIRUSTOTAL_API_KEY=

# ── Discovery safety switches ──
ALLOW_ACTIVE_DNS_BRUTEFORCE=false     # requires explicit per-job attestation

# ── Secrets vault (Phase 6) ──
VAULT_ADDR=
VAULT_TOKEN=

# ── Vendored tool paths (written by scripts/setup_tools.sh) ──
THIRD_PARTY_DIR=./third_party
